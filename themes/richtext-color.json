{
    "name": "Rich Text Colors",
    "colors": {},
    "tokenColors": [
        {
            "scope": "markup.transition.cause.richtext",
            "settings": { "foreground": "#FFB86C" }
        },
        {
            "scope": "markup.transition.result.richtext",
            "settings": { "foreground": "#50FA7B" }
        },
        {
            "scope": "markup.transition.contrast.richtext",
            "settings": { "foreground": "#FF5555" }
        },
        {
            "scope": "markup.transition.progress.richtext",
            "settings": { "foreground": "#8BE9FD" }
        },
        {
            "scope": "markup.transition.summary.richtext",
            "settings": { "foreground": "#BD93F9" }
        },
        {
            "scope": "markup.bold.richtext",
            "settings": { "foreground": "#F1FA8C", "fontStyle": "bold" }
        },
        {
            "scope": "constant.numeric.richtext",
            "settings": { "foreground": "#FFB86C" }
        },
        {
            "scope": "punctuation.definition.string.end.richtext",
            "settings": { "foreground": "#6272A4" }
        }
    ]
}