{
    "name": "powered-plaintext",
    "displayName": "Powered Plain Text",
    "description": "Semantic highlighting and logical symbol hints for plain text and LaTeX",
    "icon": "images/Icon.png",
    "version": "0.0.2",
    "publisher": "Tesla-SHT",
    "repository": {
        "type": "git",
        "url": "https://github.com/Tesla-SHT/powered-plaintext"
    },
    "license": "MIT",
    "engines": {
        "node": ">=18.0.0",
        "npm": ">=9.0.0",
        "vscode": "^1.85.0"
    },
    "categories": [
        "Themes"
    ],
    "keywords": [
        "plaintext",
        "text",
        "syntax-highlighting",
        "semantic-highlighting",
        "latex",
        "writing"
    ],
    "activationEvents": [
        "onLanguage:richtext",
        "onLanguage:latex"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "richtext",
                "aliases": [
                    "Rich Text",
                    "richtext"
                ],
                "extensions": [
                    ".txt",
                    ".rtxt",
                    ".rich"
                ],
                "configuration": "./language-configuration.json"
            },
            {
                "id": "latex",
                "extensions": [
                    ".tex",
                    ".latex"
                ]
            }
        ],
        "grammars": [
            {
                "language": "richtext",
                "scopeName": "source.rich",
                "path": "./syntaxes/richtext.tmLanguage.json",
                "injectTo": [
                    "text.tex.latex",
                    "text.tex.latex.beamer",
                    "text.tex",
                    "source.latex"
                ]
            }
        ],
        "commands": [
            {
                "command": "richtext.autoFormat",
                "title": "Rich Text: Auto Format"
            }
        ]
    },
    "scripts": {
        "preinstall": "node ./scripts/check-node-version.js",
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile"
    },
    "devDependencies": {
        "@types/vscode": "^1.85.0",
        "@types/node": "^20.x",
        "typescript": "^5.3.0"
    }
}