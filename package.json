{
    "name": "powered-plaintext",
    "displayName": "Powered Plain Text",
    "description": "Semantic highlighting and logical symbol hints for plain text, Markdown, and LaTeX",
    "icon": "images/Icon.png",
    "version": "0.1.1",
    "publisher": "Tesla-SHT",
    "repository": {
        "type": "git",
        "url": "https://github.com/Tesla-SHT/powered-plaintext"
    },
    "license": "MIT",
    "engines": {
        "node": ">=18.0.0",
        "npm": ">=9.0.0",
        "vscode": "^1.85.0"
    },
    "categories": [
        "Other"
    ],
    "keywords": [
        "plaintext",
        "text",
        "markdown",
        "syntax-highlighting",
        "semantic-highlighting",
        "latex",
        "writing",
        "academic-writing",
        "journaling",
        "notes"
    ],
    "main": "./out/extension.js",
    "activationEvents": [
        "onLanguage:markdown"
    ],
    "contributes": {
        "languages": [
            {
                "id": "richtext",
                "aliases": [
                    "Rich Text",
                    "richtext"
                ],
                "extensions": [
                    ".txt",
                    ".rtxt",
                    ".rich"
                ],
                "configuration": "./language-configuration.json"
            },
            {
                "id": "latex",
                "extensions": [
                    ".tex",
                    ".latex"
                ]
            }
        ],
        "grammars": [
            {
                "language": "richtext",
                "scopeName": "source.rich",
                "path": "./syntaxes/richtext.tmLanguage.json",
                "injectTo": [
                    "text.html.markdown",
                    "text.tex.latex",
                    "text.tex.latex.beamer",
                    "text.tex",
                    "source.latex"
                ]
            }
        ],
        "commands": [
            {
                "command": "richtext.autoFormat",
                "title": "Powered Plain Text: Auto Format"
            }
        ],
        "configuration": {
            "title": "Powered Plain Text",
            "properties": {
                "poweredPlaintext.writingProfile": {
                    "type": "string",
                    "enum": [
                        "general",
                        "academic",
                        "journal",
                        "notes"
                    ],
                    "default": "general",
                    "markdownDescription": "Choose a built-in vocabulary profile tuned for general writing, academic writing, journaling, or notes."
                },
                "poweredPlaintext.enableSymbolHints": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "Show logical symbol hints such as →, ⇒, ⇄, ⊕, ◆, and numbered sequence markers in supported documents."
                },
                "poweredPlaintext.customTransitionWords": {
                    "type": "object",
                    "default": {
                        "causation": [],
                        "result": [],
                        "contrast": [],
                        "addition": [],
                        "summary": [],
                        "example": []
                    },
                    "markdownDescription": "Add your own transition words or phrases for each logical category.",
                    "properties": {
                        "causation": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            },
                            "default": []
                        },
                        "result": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            },
                            "default": []
                        },
                        "contrast": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            },
                            "default": []
                        },
                        "addition": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            },
                            "default": []
                        },
                        "summary": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            },
                            "default": []
                        },
                        "example": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            },
                            "default": []
                        }
                    }
                },
                "poweredPlaintext.customSequenceWords": {
                    "type": "object",
                    "default": {
                        "starters": [],
                        "continuers": [],
                        "terminators": []
                    },
                    "markdownDescription": "Add your own sequence markers that should receive numbered symbol hints.",
                    "properties": {
                        "starters": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            },
                            "default": []
                        },
                        "continuers": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            },
                            "default": []
                        },
                        "terminators": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            },
                            "default": []
                        }
                    }
                },
                "poweredPlaintext.autoFormatParagraphBreakWords": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "markdownDescription": "Additional words or phrases that should trigger a blank line before a new paragraph when using Auto Format."
                }
            }
        }
    },
    "scripts": {
        "preinstall": "node ./scripts/check-node-version.js",
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile"
    },
    "devDependencies": {
        "@types/vscode": "^1.85.0",
        "@types/node": "^20.x",
        "typescript": "^5.3.0"
    }
}