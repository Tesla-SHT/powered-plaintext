{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "richtext",
    "injectionSelector": "L:text.tex.latex, L:text.tex, L:source.latex",
    "patterns": [
        { "include": "#punctuation" },
        { "include": "#quotes" },
        { "include": "#bookTitles" },
        { "include": "#parentheses" },
        { "include": "#numbers" }
    ],
    "repository": {
        "punctuation": {
            "patterns": [
                {
                    "name": "punctuation.definition.richtext",
                    "match": "[。，、；：！？,.;:!?]"
                }
            ]
        },
        "quotes": {
            "patterns": [
                {
                    "name": "string.quoted.double.richtext",
                    "match": "\"[^\"]*\"|'[^']*'"
                }
            ]
        },
        "bookTitles": {
            "patterns": [
                {
                    "name": "entity.name.type.richtext",
                    "match": "《[^》]*》"
                }
            ]
        },
        "parentheses": {
            "patterns": [
                {
                    "name": "comment.block.richtext",
                    "match": "\\([^)]*\\)|（[^）]*）|【[^】]*】|\\[[^\\]]*\\]"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.richtext",
                    "match": "\\b\\d+(\\.\\d+)?%?\\b|[一二三四五六七八九十百千万]+[个条项点]?"
                }
            ]
        }
    },
    "scopeName": "source.rich"
}